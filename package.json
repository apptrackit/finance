{
  "name": "finance-manager",
  "version": "2.7",
  "private": true,
  "workspaces": [
    "client",
    "api",
    "mcp"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w client\" \"npm run dev -w api\"",
    "build": "npm run build -w client",
    "build:mcp": "npm run build -w mcp",
    "test:mcp": "npm run test -w mcp",
    "deploy": "./deploy.sh",
    "deploy:mcp": "./deploy.sh --mcp"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "yahoo-finance2": "^3.10.2"
  }
}
